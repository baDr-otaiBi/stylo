{#
  Vogue Fashion Theme - Footer Component
  Elegant fashion-forward footer
#}

<footer class="vf-footer">
    {# Main Footer #}
    <div class="vf-footer__main">
        <div class="vf-container">
            <div class="vf-footer__grid">
                {# Brand Column #}
                <div class="vf-footer__brand">
                    {% if store.logo %}
                        <img src="{{ store.logo }}" alt="{{ store.name }}" class="vf-footer__logo">
                    {% else %}
                        <h3 class="vf-footer__store-name">{{ store.name }}</h3>
                    {% endif %}

                    {% if store.description %}
                        <p class="vf-footer__desc">{{ store.description|slice(0, 150) }}</p>
                    {% endif %}

                    {# Social Links #}
                    <div class="vf-footer__social">
                        {% if store.settings.social.instagram %}
                            <a href="{{ store.settings.social.instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
                                <i class="sicon-instagram"></i>
                            </a>
                        {% endif %}
                        {% if store.settings.social.twitter %}
                            <a href="{{ store.settings.social.twitter }}" target="_blank" rel="noopener" aria-label="Twitter">
                                <i class="sicon-twitter"></i>
                            </a>
                        {% endif %}
                        {% if store.settings.social.snapchat %}
                            <a href="{{ store.settings.social.snapchat }}" target="_blank" rel="noopener" aria-label="Snapchat">
                                <i class="sicon-snapchat"></i>
                            </a>
                        {% endif %}
                        {% if store.settings.social.tiktok %}
                            <a href="{{ store.settings.social.tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">
                                <i class="sicon-tiktok"></i>
                            </a>
                        {% endif %}
                    </div>
                </div>

                {# Quick Links #}
                <div class="vf-footer__links">
                    <h4 class="vf-footer__heading">{{ trans('themes.footer.quick_links') }}</h4>
                    <ul>
                        <li><a href="{{ link('products') }}">{{ trans('themes.footer.all_products') }}</a></li>
                        <li><a href="{{ link('brands') }}">{{ trans('themes.footer.brands') }}</a></li>
                        <li><a href="{{ link('blog') }}">{{ trans('themes.footer.blog') }}</a></li>
                        {% for page in store.pages %}
                            <li><a href="{{ page.url }}">{{ page.title }}</a></li>
                        {% endfor %}
                    </ul>
                </div>

                {# Customer Service #}
                <div class="vf-footer__links">
                    <h4 class="vf-footer__heading">{{ trans('themes.footer.customer_service') }}</h4>
                    <ul>
                        <li><a href="{{ link('profile') }}">{{ trans('themes.footer.my_account') }}</a></li>
                        <li><a href="{{ link('orders') }}">{{ trans('themes.footer.track_order') }}</a></li>
                        <li><a href="{{ link('wishlist') }}">{{ trans('themes.footer.wishlist') }}</a></li>
                    </ul>
                </div>

                {# Contact Info #}
                <div class="vf-footer__contact">
                    <h4 class="vf-footer__heading">{{ trans('themes.footer.get_in_touch') }}</h4>
                    {% if store.settings.email %}
                        <a href="mailto:{{ store.settings.email }}" class="vf-footer__contact-item">
                            <i class="sicon-mail"></i>
                            <span>{{ store.settings.email }}</span>
                        </a>
                    {% endif %}
                    {% if store.settings.phone %}
                        <a href="tel:{{ store.settings.phone }}" class="vf-footer__contact-item">
                            <i class="sicon-phone"></i>
                            <span>{{ store.settings.phone }}</span>
                        </a>
                    {% endif %}

                    {# Payment Methods #}
                    <div class="vf-footer__payments">
                        <span class="vf-footer__payments-label">{{ trans('themes.footer.we_accept') }}</span>
                        <div class="vf-footer__payment-icons">
                            <salla-payment-methods></salla-payment-methods>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Bottom Bar #}
    <div class="vf-footer__bottom">
        <div class="vf-container flex flex-col md:flex-row items-center justify-between gap-3">
            <p class="vf-footer__copyright">
                &copy; {{ 'now'|date('Y') }} {{ store.name }}. {{ trans('themes.footer.all_rights_reserved') }}
            </p>
            <a href="https://salla.sa" target="_blank" rel="noopener" class="vf-footer__powered">
                {{ trans('themes.footer.powered_by') }} <strong>Salla</strong>
            </a>
        </div>
    </div>
</footer>

