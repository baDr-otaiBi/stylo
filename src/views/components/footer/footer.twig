<footer class="store-footer stylo-footer">
    {# Newsletter Section #}
    <div class="stylo-newsletter">
        <div class="container text-center py-12 lg:py-16">
            <h3 class="stylo-newsletter__title">{{ trans('blocks.footer.newsletter') | default('انضم لقائمتنا البريدية') }}</h3>
            <p class="stylo-newsletter__desc">{{ trans('blocks.footer.newsletter_desc') | default('كن أول من يعرف عن أحدث المجموعات والعروض الحصرية') }}</p>
            <salla-newsletter class="mt-6 max-w-md mx-auto"></salla-newsletter>
        </div>
    </div>

	<div aria-label="footer" class="store-footer__inner">
		<div class="container grid grid-col-1 lg:grid-cols-6 gap-8 lg:gap-6">
			<div class="lg:col-span-2 rtl:lg:pl-20 ltr:lg:pr-20">
				<a href="{{ link('/') }}" class="flex items-center m-0">
					<h3 class="stylo-footer__brand">{{store.name}}</h3>
				</a>
				{% if store.description %}
					<div class="max-w-sm leading-7 mb-6 text-gray-400 text-sm">
						{{ store.description|raw }}
          </div>
				{% endif %}

				<div class="hidden lg:block">
					<salla-social class="block mb-6"></salla-social>
				</div>

		<div class="flex gap-4">
		  <salla-trust-badges dark></salla-trust-badges>
          {% if store.settings.tax.number %}
            <div class="flex rtl:space-x-reverse space-x-2 items-end">
              {% if store.settings.tax.certificate %}
                <a class="load-img-onclick" data-modal-id="modal-value-tax" href="#/" alt="{{ store.settings.tax.number }}">
                  <img width="40" height="50" src="{{'images/tax.png' | cdn(70,70)}}" loading="lazy" class="w-10 rounded-sm hover:opacity-80 transition-opacity" alt="value added tax">
                </a>
              {% endif %}
              <div>
                <p class="text-sm text-gray-500 mb-1">{{ trans('common.elements.tax_number') }}</p>
                <b class="text-sm">{{ store.settings.tax.number }}</b>
              </div>
            </div>

            {% if store.settings.tax.certificate %}
              <salla-modal sub-title-first sub-title="{{ trans('common.elements.tax_number') }}" modal-title="{{ store.settings.tax.number }}" id="modal-value-tax">
                <div class="flex justify-center max-w-full">
                  <img class="w-full" loading="lazy" 
                  src="{{ store.settings.tax.certificate }}" 
                  alt="{{ store.settings.tax.number }}"/>
                </div>
              </salla-modal>
            {% endif %}
          {% endif %}
        </div>
        </div>

			<div>
				<h3 class="stylo-footer__heading">{{ trans('blocks.footer.pages_links') }}</h3>
				<salla-menu source="footer"></salla-menu>
			</div>

			<div>
				<salla-contacts></salla-contacts>

				<div class="lg:hidden contact-social mt-6">
					<salla-social></salla-social>
				</div>
			</div>

			<salla-apps-icons class="lg:col-span-2 rtl:lg:pr-20 ltr:lg:pl-20"></salla-apps-icons>

		</div>
	</div>

	<div class="md:flex items-center justify-between py-5 container text-center border-t border-gray-800">
		<span class="text-sm text-gray-500 copyright-text">{% hook copyright %}</span>
		<salla-payments></salla-payments>
	</div>
</footer>

<span class="hidden bottom-2 rtl:pl-24 ltr:pr-24 md:grid-cols-3 opacity-40"></span>
