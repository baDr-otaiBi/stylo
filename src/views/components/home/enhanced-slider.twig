{#
| Variable                       | Type     | Description                                                                  |
|--------------------------------|----------|------------------------------------------------------------------------------|
| component                      | object   | Contains merchant settings for fields from twilight.json `component` section |
| component.slides[].image       | string   | Image url                                                                    |
| component.slides[].title       | ?string  |                                                                              |
| component.slides[].description | ?string  |                                                                              |
| component.slides               | object[] | list of slides                                                               |
| position                       | int      | Sorting number start from zero                                               |
#}
<section class="s-block s-block--hero-slider s-block--full-bg wide-placeholder stylo-hero"> 
    <salla-slider 
      id="main-slider-{{ position }}"
      auto-play
      static-when-single
      slider-config='{"lazy":"false"}'
      {{ component.slides|length > 1 ? '' : 'show-controls="false"' }}
      type="fullwidth">
        <div slot="items">
            {% for slide in component.slides %}
                <div class="swiper-slide w-full min-h-[400px] lg:min-h-[600px] bg-dark relative">
					<div style="background-image: url({{ slide.image }});" class="{{ slide.without_overlay ? '' : 'overlay-bg' }} bg-cover bg-center absolute inset-0"></div>
                    <div class="flex-center container pb-16 sm:pb-0 home-slider__content relative h-full">
                        <div class="w-5/6 text-center md:w-7/12 lg:w-5/12 text-white">
                            {% if slide.title %}
                                <span class="stylo-hero__tag">{{ trans('common.titles.new_collection') | default('NEW COLLECTION') }}</span>
                                <h2 data-swiper-parallax="-500" class="stylo-hero__title">{{ slide.title }}</h2>
                            {% endif %}
                            {% if slide.description %}
                                <p data-swiper-parallax="-300" class="stylo-hero__desc">{{ slide.description }}</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </salla-slider>
</section>
