{#
  Vogue Fashion Theme - Single Product Page
  Fashion-optimized product detail page
#}

{% extends "layouts/master.twig" %}

{% block content %}
<div class="vf-product-page">
    <div class="vf-container">

        {# Breadcrumb #}
        <nav class="vf-breadcrumb" aria-label="Breadcrumb">
            <a href="{{ store.url }}">{{ trans('themes.common.home') }}</a>
            <span class="vf-breadcrumb__sep">/</span>
            {% if product.category %}
                <a href="{{ product.category.url }}">{{ product.category.name }}</a>
                <span class="vf-breadcrumb__sep">/</span>
            {% endif %}
            <span class="vf-breadcrumb__current">{{ product.name }}</span>
        </nav>

        <div class="vf-product-layout">
            {# ==================== PRODUCT GALLERY ==================== #}
            <div class="vf-product-gallery">
                {# Main Image #}
                <div class="vf-product-gallery__main" id="productMainImage">
                    <div class="vf-product-gallery__zoom">
                        <img src="{{ product.image.url }}"
                             alt="{{ product.image.alt | default(product.name) }}"
                             class="vf-product-gallery__img"
                             id="mainProductImage">

                        {# Badges #}
                        {% if product.is_on_sale %}
                            <span class="vf-badge vf-badge--sale vf-badge--large">
                                {{ product.discount_percentage }}% {{ trans('themes.product.off') }}
                            </span>
                        {% endif %}
                    </div>
                </div>

                {# Thumbnail Gallery #}
                {% if product.images|length > 1 %}
                <div class="vf-product-gallery__thumbs">
                    {% for image in product.images %}
                        <button class="vf-product-gallery__thumb {{ loop.first ? 'active' : '' }}"
                                data-image="{{ image.url }}"
                                onclick="changeMainImage(this)">
                            <img src="{{ image.url }}" alt="{{ image.alt | default(product.name) }}" loading="lazy">
                        </button>
                    {% endfor %}
                </div>
                {% endif %}
            </div>

            {# ==================== PRODUCT INFO ==================== #}
            <div class="vf-product-info">
                {# Brand #}
                {% if product.brand %}
                    <a href="{{ product.brand.url }}" class="vf-product-info__brand">
                        {{ product.brand.name }}
                    </a>
                {% endif %}

                {# Title #}
                <h1 class="vf-product-info__title">{{ product.name }}</h1>

                {# Rating #}
                {% if product.rating and product.rating.count > 0 %}
                <div class="vf-product-info__rating">
                    <div class="vf-stars">
                        {% for i in 1..5 %}
                            <i class="sicon-star{% if i > product.rating.stars %}-o{% endif %}"></i>
                        {% endfor %}
                    </div>
                    <span>({{ product.rating.count }} {{ trans('themes.product.reviews') }})</span>
                </div>
                {% endif %}

                {# Price #}
                <div class="vf-product-info__price">
                    {% if product.is_on_sale %}
                        <span class="vf-price-main vf-price-main--sale">{{ product.sale_price }}</span>
                        <span class="vf-price-original">{{ product.regular_price }}</span>
                        <span class="vf-price-save">
                            {{ trans('themes.product.you_save') }} {{ product.discount_percentage }}%
                        </span>
                    {% else %}
                        <span class="vf-price-main">{{ product.price }}</span>
                    {% endif %}

                    {% if store.settings.tax_included %}
                        <span class="vf-tax-note">{{ trans('themes.product.tax_included') }}</span>
                    {% endif %}
                </div>

                {# Short Description #}
                {% if product.short_description %}
                <div class="vf-product-info__desc">
                    {{ product.short_description }}
                </div>
                {% endif %}

                {# Product Options (Size, Color, etc.) #}
                <salla-product-options product-id="{{ product.id }}" class="vf-product-options">
                </salla-product-options>

                {# Size Guide Button #}
                {% if theme.settings.show_size_guide %}
                <button class="vf-size-guide-btn" onclick="document.getElementById('sizeGuideModal').classList.add('active')">
                    <i class="sicon-ruler"></i>
                    {{ trans('themes.product.size_guide') }}
                </button>
                {% endif %}

                {# Quantity & Add to Cart #}
                <div class="vf-product-actions">
                    <salla-quantity-input product-id="{{ product.id }}" class="vf-quantity">
                    </salla-quantity-input>

                    <salla-add-product-btn product-id="{{ product.id }}" class="vf-btn vf-btn--primary vf-btn--full">
                        <i class="sicon-shopping-bag"></i>
                        {{ trans('themes.product.add_to_cart') }}
                    </salla-add-product-btn>
                </div>

                {# Buy Now #}
                <salla-add-product-btn product-id="{{ product.id }}" quick-buy class="vf-btn vf-btn--secondary vf-btn--full">
                    {{ trans('themes.product.buy_now') }}
                </salla-add-product-btn>

                {# Wishlist & Share #}
                <div class="vf-product-meta-actions">
                    <salla-wishlist-btn product-id="{{ product.id }}" class="vf-meta-action">
                        <i class="sicon-heart"></i>
                        <span>{{ trans('themes.product.add_to_wishlist') }}</span>
                    </salla-wishlist-btn>

                    <salla-share-btn class="vf-meta-action">
                        <i class="sicon-share"></i>
                        <span>{{ trans('themes.product.share') }}</span>
                    </salla-share-btn>
                </div>

                {# Trust Badges #}
                <div class="vf-trust-badges">
                    <div class="vf-trust-badge">
                        <i class="sicon-shipping-fast"></i>
                        <span>{{ trans('themes.product.fast_shipping') }}</span>
                    </div>
                    <div class="vf-trust-badge">
                        <i class="sicon-repeat"></i>
                        <span>{{ trans('themes.product.easy_returns') }}</span>
                    </div>
                    <div class="vf-trust-badge">
                        <i class="sicon-lock"></i>
                        <span>{{ trans('themes.product.secure_payment') }}</span>
                    </div>
                </div>

                {# SKU & Categories #}
                <div class="vf-product-meta">
                    {% if product.sku %}
                        <div class="vf-product-meta__item">
                            <span>{{ trans('themes.product.sku') }}:</span>
                            <span>{{ product.sku }}</span>
                        </div>
                    {% endif %}
                    {% if product.category %}
                        <div class="vf-product-meta__item">
                            <span>{{ trans('themes.product.category') }}:</span>
                            <a href="{{ product.category.url }}">{{ product.category.name }}</a>
                        </div>
                    {% endif %}
                    {% if product.tags|length > 0 %}
                        <div class="vf-product-meta__item">
                            <span>{{ trans('themes.product.tags') }}:</span>
                            {% for tag in product.tags %}
                                <a href="{{ tag.url }}">{{ tag.name }}{% if not loop.last %}, {% endif %}</a>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# ==================== PRODUCT TABS ==================== #}
        <div class="vf-product-tabs" id="productTabs">
            <div class="vf-tabs-nav">
                <button class="vf-tab-btn active" data-tab="description">
                    {{ trans('themes.product.description') }}
                </button>
                {% if product.has_specifications %}
                <button class="vf-tab-btn" data-tab="specifications">
                    {{ trans('themes.product.specifications') }}
                </button>
                {% endif %}
                <button class="vf-tab-btn" data-tab="reviews">
                    {{ trans('themes.product.reviews') }}
                    {% if product.rating %}({{ product.rating.count }}){% endif %}
                </button>
            </div>

            <div class="vf-tabs-content">
                <div class="vf-tab-panel active" id="tab-description">
                    <div class="vf-prose">
                        {{ product.description|raw }}
                    </div>
                </div>

                {% if product.has_specifications %}
                <div class="vf-tab-panel" id="tab-specifications">
                    <table class="vf-specs-table">
                        {% for spec in product.specifications %}
                        <tr>
                            <td class="vf-specs-table__label">{{ spec.name }}</td>
                            <td class="vf-specs-table__value">{{ spec.value }}</td>
                        </tr>
                        {% endfor %}
                    </table>
                </div>
                {% endif %}

                <div class="vf-tab-panel" id="tab-reviews">
                    <salla-product-rating product-id="{{ product.id }}"></salla-product-rating>
                    {% include 'components/product/comments.twig' %}
                </div>
            </div>
        </div>

        {# ==================== RELATED PRODUCTS ==================== #}
        {% if product.related_products|length > 0 %}
        <section class="vf-section vf-related-products">
            <div class="vf-section-header text-center">
                <span class="vf-section-tag">{{ trans('themes.product.you_may_also_like') }}</span>
                <h2 class="vf-section-title">{{ trans('themes.product.complete_the_look') }}</h2>
            </div>

            <div class="vf-products-grid vf-products-grid--4">
                {% for related in product.related_products|slice(0, 4) %}
                    {% include 'pages/product/card.twig' with { product: related } %}
                {% endfor %}
            </div>
        </section>
        {% endif %}
    </div>
</div>

{# ==================== SIZE GUIDE MODAL ==================== #}
{% if theme.settings.show_size_guide %}
<div class="vf-modal" id="sizeGuideModal">
    <div class="vf-modal__overlay" onclick="this.parentElement.classList.remove('active')"></div>
    <div class="vf-modal__content">
        <div class="vf-modal__header">
            <h3>{{ trans('themes.product.size_guide') }}</h3>
            <button onclick="this.closest('.vf-modal').classList.remove('active')" aria-label="Close">
                <i class="sicon-cancel"></i>
            </button>
        </div>
        <div class="vf-modal__body">
            <table class="vf-size-table">
                <thead>
                    <tr>
                        <th>{{ trans('themes.product.size') }}</th>
                        <th>{{ trans('themes.product.chest') }} (cm)</th>
                        <th>{{ trans('themes.product.waist') }} (cm)</th>
                        <th>{{ trans('themes.product.hips') }} (cm)</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td>XS</td><td>78-82</td><td>60-64</td><td>86-90</td></tr>
                    <tr><td>S</td><td>82-86</td><td>64-68</td><td>90-94</td></tr>
                    <tr><td>M</td><td>86-90</td><td>68-72</td><td>94-98</td></tr>
                    <tr><td>L</td><td>90-94</td><td>72-76</td><td>98-102</td></tr>
                    <tr><td>XL</td><td>94-98</td><td>76-80</td><td>102-106</td></tr>
                    <tr><td>XXL</td><td>98-102</td><td>80-84</td><td>106-110</td></tr>
                </tbody>
            </table>
            <p class="vf-size-note">{{ trans('themes.product.size_guide_note') }}</p>
        </div>
    </div>
</div>
{% endif %}

<script>
// Image gallery
function changeMainImage(thumb) {
    const mainImg = document.getElementById('mainProductImage');
    const newSrc = thumb.getAttribute('data-image');
    mainImg.src = newSrc;
    document.querySelectorAll('.vf-product-gallery__thumb').forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
}

// Tabs
document.querySelectorAll('.vf-tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        const tab = btn.dataset.tab;
        document.querySelectorAll('.vf-tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.vf-tab-panel').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('tab-' + tab).classList.add('active');
    });
});
</script>
{% endblock %}

