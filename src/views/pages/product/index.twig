{#
  Vogue Fashion Theme - Products Listing Page
#}

{% extends "layouts/master.twig" %}

{% block content %}
<div class="vf-products-page">
    <div class="vf-container">

        {# Page Header #}
        <div class="vf-page-header">
            <nav class="vf-breadcrumb">
                <a href="{{ store.url }}">{{ trans('themes.common.home') }}</a>
                <span class="vf-breadcrumb__sep">/</span>
                {% if category %}
                    <span class="vf-breadcrumb__current">{{ category.name }}</span>
                {% else %}
                    <span class="vf-breadcrumb__current">{{ trans('themes.common.products') }}</span>
                {% endif %}
            </nav>

            <div class="vf-page-header__title-row">
                <h1 class="vf-page-title">
                    {% if category %}
                        {{ category.name }}
                    {% else %}
                        {{ trans('themes.common.products') }}
                    {% endif %}
                </h1>
                {% if products.total is defined %}
                    <span class="vf-results-count">({{ products.total }} {{ trans('themes.home.products') }})</span>
                {% endif %}
            </div>
        </div>

        {# Filters & Sort Bar #}
        <div class="vf-toolbar">
            <div class="vf-toolbar__filters">
                <salla-filters></salla-filters>
            </div>
            <div class="vf-toolbar__sort">
                <salla-products-sort></salla-products-sort>
            </div>
        </div>

        {# Products Grid #}
        <div class="vf-products-grid" id="productsGrid">
            {% for product in products %}
                {% include 'pages/product/card.twig' with { product: product } %}
            {% endfor %}
        </div>

        {# Empty State #}
        {% if products|length == 0 %}
        <div class="vf-empty-state">
            <i class="sicon-shopping-bag"></i>
            <h3>{{ trans('themes.common.no_products') | default('لا توجد منتجات') }}</h3>
        </div>
        {% endif %}

        {# Pagination #}
        {% if products.links is defined %}
        <nav class="vf-pagination">
            <salla-products-pagination></salla-products-pagination>
        </nav>
        {% endif %}

    </div>
</div>
{% endblock %}
