{#
  STYLO Theme - Master Layout
  Built on Salla Twilight Engine
  Designed for fashion/clothing stores
#}

<!DOCTYPE html>
<html lang="{{ store.settings.lang }}" dir="{{ store.settings.lang == 'ar' ? 'rtl' : 'ltr' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">

    {# SEO Meta #}
    <title>{{ page.title }} | {{ store.name }}</title>
    <meta name="description" content="{{ page.description|default(store.description) }}">

    {# Open Graph #}
    <meta property="og:title" content="{{ page.title }}">
    <meta property="og:description" content="{{ page.description|default(store.description) }}">
    <meta property="og:image" content="{{ store.logo }}">
    <meta property="og:url" content="{{ page.url }}">
    <meta property="og:type" content="website">

    {# Favicon #}
    <link rel="icon" href="{{ store.favicon }}" type="image/x-icon">

    {# Google Fonts - Fashion typography #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Outfit:wght@300;400;500;600;700&family=Noto+Kufi+Arabic:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    {# Salla Theme Font (if set) #}
    {% if theme.font %}
        <link rel="stylesheet" href="{{ theme.font.url }}">
    {% endif %}

    {# Salla Icons #}
    <link rel="stylesheet" href="{{ 'salla-icons.css' | asset }}">

    {# Theme Styles #}
    <link rel="stylesheet" href="{{ 'app.css' | asset }}">

    {# CSS Variables - Fashion Palette #}
    <style>
        :root {
            /* Primary Brand Colors */
            --vf-primary: {{ theme.color.primary | default('#1a1a1a') }};
            --vf-primary-light: {{ theme.color.lighter(0.15) | default('#333333') }};
            --vf-primary-dark: {{ theme.color.darker(0.15) | default('#000000') }};

            /* Fashion Neutrals */
            --vf-cream: #FAF7F2;
            --vf-sand: #E8E0D4;
            --vf-charcoal: #2C2C2C;
            --vf-graphite: #4A4A4A;
            --vf-silver: #B8B8B8;
            --vf-white: #FFFFFF;
            --vf-off-white: #FAFAFA;
            --vf-black: #0A0A0A;

            /* Accent Colors */
            --vf-gold: #C9A96E;
            --vf-rose: #D4A0A0;
            --vf-sage: #A8B5A0;

            /* Typography */
            --vf-font-display: 'Playfair Display', 'Noto Kufi Arabic', serif;
            --vf-font-body: 'Outfit', 'Noto Kufi Arabic', sans-serif;

            /* Spacing */
            --vf-section-gap: 5rem;
            --vf-container-max: 1320px;
            --vf-container-padding: 1.5rem;

            /* Transitions */
            --vf-transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            --vf-transition-smooth: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            --vf-transition-elegant: 0.6s cubic-bezier(0.22, 1, 0.36, 1);

            /* Borders */
            --vf-radius-sm: 4px;
            --vf-radius-md: 8px;
            --vf-radius-lg: 16px;

            /* Shadows */
            --vf-shadow-soft: 0 2px 20px rgba(0, 0, 0, 0.06);
            --vf-shadow-medium: 0 4px 30px rgba(0, 0, 0, 0.1);
            --vf-shadow-elevated: 0 8px 40px rgba(0, 0, 0, 0.15);
        }
    </style>

    {# Head Hook - For additional scripts/styles #}
    {% hook 'head' %}
</head>
<body class="vf-body font-body antialiased {{ page.slug }}
    {% if store.settings.lang == 'ar' %}vf-rtl{% endif %}"
>
    {# Announcement Bar #}
    {% if store.settings.announcement %}
    <div class="vf-announcement-bar bg-black text-white text-center py-2 text-sm tracking-widest uppercase">
        <div class="vf-container">
            {{ store.settings.announcement }}
        </div>
    </div>
    {% endif %}

    {# Header Component #}
    {% component 'header' %}

    {# Main Content #}
    <main class="vf-main" id="main-content">
        {% block content %}{% endblock %}
    </main>

    {# Footer Component #}
    {% component 'footer' %}

    {# Back to Top Button #}
    <button class="vf-back-to-top" id="backToTop" aria-label="Back to top">
        <i class="sicon-keyboard_arrow_up"></i>
    </button>

    {# Salla Web Components #}
    <salla-offer-modal></salla-offer-modal>
    <salla-search></salla-search>

    {# Scripts #}
    <script src="{{ 'app.js' | asset }}"></script>

    {# Footer Hook #}
    {% hook 'footer' %}

    {# Back to top script #}
    <script>
        const backToTop = document.getElementById('backToTop');
        window.addEventListener('scroll', () => {
            backToTop.classList.toggle('visible', window.scrollY > 600);
        });
        backToTop.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    </script>
</body>
</html>

